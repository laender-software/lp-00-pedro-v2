---
const bundles = [
  {
    number: "1",
    title: "Diagnóstico & Copy Estratégica",
    highlight: "Você não precisa escrever uma linha",
    items: [
      "Briefing rápido de 10-15 minutos",
      "Pesquisa do público da sua especialidade",
      "Textos profissionais escritos para você",
      "Se já tem texto ou público definido, usamos e aprimoramos",
    ],
    footer: null,
  },
  {
    number: "2",
    title: "Presença Digital Completa",
    highlight: "Pronto em 5 dias úteis",
    items: [
      "Domínio próprio registrado e configurado",
      "Site responsivo — bonito no celular e no computador",
      "Seu nome vai estar lá, vai estar no ar, não vai cair",
      "Site rápido — carrega em menos de 2 segundos, do jeito que o Google gosta",
    ],
    footer: "Domínio, hospedagem, configuração — nós cuidamos de tudo.",
  },
  {
    number: "3",
    title: "Design Profissional Exclusivo",
    highlight: "Nunca replicado para outro médico",
    items: [
      "Design criado especificamente para a sua especialidade",
      "Visual premium que transmite autoridade",
      "1 rodada de ajustes inclusa",
    ],
    footer: null,
  },
  {
    number: "4",
    title: "No ar por 5 anos",
    highlight: "Investimento único — zero mensalidade",
    items: [
      "Site mantido funcionando por 5 anos completos",
      "Ajustes inclusos: foto, texto, telefone, endereço, depoimentos",
      "Monitoramento ativo — se algo sair do ar, resolvemos antes de você perceber",
      "Suporte direto via WhatsApp",
    ],
    footer: "Pagou uma vez, não se preocupa mais. Qualquer coisa, me chama no WhatsApp.",
  },
];
---

<section id="bundles" class="py-20 md:py-28 bg-bg-alt reveal">
  <div class="mx-auto max-w-5xl px-6">
    <div class="text-center">
      <span class="text-xs font-semibold uppercase tracking-widest text-accent">O que está incluso</span>
      <h2 class="mt-4 font-serif text-3xl md:text-4xl font-bold text-text leading-tight">
        Tudo o que seu site precisa. Sem você se preocupar com nada.
      </h2>
    </div>

    <div class="mt-14 grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8 stagger">
      {bundles.map((bundle) => (
        <div class="bg-white rounded-2xl p-6 md:p-8 border border-border card-lift flex flex-col reveal">
          <div class="flex items-center gap-3 mb-5">
            <span class="inline-flex items-center justify-center w-9 h-9 rounded-full bg-[#DBEAFE] font-serif text-brand font-bold text-sm shrink-0">
              {bundle.number}
            </span>
            <h3 class="font-semibold text-lg text-text leading-snug">{bundle.title}</h3>
          </div>

          <ul class="space-y-3 flex-1">
            {bundle.items.map((item) => (
              <li class="flex items-start gap-2.5 text-muted text-sm">
                <svg class="w-5 h-5 text-brand mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>

          <div class="mt-5 pt-4 border-t border-border">
            <p class="text-sm font-bold text-accent">{bundle.highlight}</p>
          </div>

          {bundle.footer && (
            <p class="mt-3 text-sm text-muted italic">{bundle.footer}</p>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
