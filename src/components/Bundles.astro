---
const bundles = [
  {
    number: "1",
    title: "Diagnóstico & Copy Estratégica",
    highlight: "Você não precisa escrever uma linha",
    items: [
      "Briefing rápido de 10-15 minutos",
      "Pesquisa do público da sua especialidade",
      "Textos profissionais escritos para você",
      "Se já tem texto ou público definido, usamos e aprimoramos",
    ],
    footer: null,
  },
  {
    number: "2",
    title: "Presença Digital Completa",
    highlight: "Pronto em 5 dias úteis",
    items: [
      "Domínio próprio registrado e configurado",
      "Site responsivo — bonito no celular e no computador",
      "Seu nome vai estar lá, vai estar no ar, não vai cair",
      "Site rápido — carrega em menos de 2 segundos, do jeito que o Google gosta",
    ],
    footer: "Domínio, hospedagem, configuração — nós cuidamos de tudo.",
  },
  {
    number: "3",
    title: "Design Profissional Exclusivo",
    highlight: "Nunca replicado para outro médico",
    items: [
      "Design criado especificamente para a sua especialidade",
      "Visual premium que transmite autoridade",
      "1 rodada de ajustes inclusa",
    ],
    footer: null,
  },
  {
    number: "4",
    title: "No ar por 5 anos",
    highlight: "Investimento único — zero mensalidade",
    items: [
      "Site mantido funcionando por 5 anos completos",
      "Ajustes inclusos: foto, texto, telefone, endereço, depoimentos",
      "Monitoramento ativo — se algo sair do ar, resolvemos antes de você perceber",
      "Suporte direto via WhatsApp",
    ],
    footer: "Pagou uma vez, não se preocupa mais. Qualquer coisa, me chama no WhatsApp.",
  },
];
---

<section class="py-20 md:py-28 bg-neutral-50 fade-in-section">
  <div class="mx-auto max-w-5xl px-5">
    <h2 class="font-serif text-3xl md:text-4xl font-bold text-brand-900 text-center leading-tight">
      Tudo o que seu site precisa. Sem você se preocupar com nada.
    </h2>

    <div class="mt-14 grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
      {bundles.map((bundle) => (
        <div class="bg-white rounded-2xl p-6 md:p-8 shadow-sm hover:shadow-md transition-shadow border border-neutral-100 flex flex-col">
          <div class="flex items-center gap-3 mb-5">
            <span class="inline-flex items-center justify-center w-9 h-9 rounded-full bg-accent-500 text-brand-900 font-bold text-sm shrink-0">
              {bundle.number}
            </span>
            <h3 class="font-semibold text-lg text-brand-900 leading-snug">{bundle.title}</h3>
          </div>

          <ul class="space-y-3 flex-1">
            {bundle.items.map((item) => (
              <li class="flex items-start gap-2.5 text-neutral-600">
                <svg class="w-5 h-5 text-brand-500 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>

          <div class="mt-5 pt-4 border-t border-neutral-100">
            <p class="text-sm font-bold text-accent-500">{bundle.highlight}</p>
          </div>

          {bundle.footer && (
            <p class="mt-3 text-sm text-neutral-500 italic">{bundle.footer}</p>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
