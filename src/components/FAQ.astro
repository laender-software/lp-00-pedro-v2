---
const faqs = [
  {
    question: "Quanto tempo leva para ficar pronto?",
    answer: "5 dias úteis a partir do briefing. Sem enrolação, sem atrasos.",
  },
  {
    question: "Preciso escrever os textos do site?",
    answer: "Não. Pesquisamos sua especialidade, escrevemos os textos e criamos o design. Você só responde o briefing de 10-15 minutos.",
  },
  {
    question: "Tem reunião?",
    answer: "Não. Sem call, sem Zoom, sem bloquear agenda. Tudo simples e direto.",
  },
  {
    question: "E se eu não gostar do resultado?",
    answer: "Você tem 14 dias após a entrega para pedir reembolso integral. Sem perguntas.",
  },
  {
    question: "O site é exclusivo ou usa template?",
    answer: "Exclusivo. O design é criado para a sua especialidade. Nunca replicado para outro médico.",
  },
  {
    question: "O que acontece depois dos 5 anos?",
    answer: "Você pode renovar o suporte por um valor reduzido. O site continua seu para sempre.",
  },
  {
    question: "Posso pedir ajustes depois?",
    answer: "Sim. Trocar foto, texto, telefone, endereço, depoimentos — tudo incluso nos 5 anos. É só chamar no WhatsApp.",
  },
  {
    question: "Preciso ter foto profissional?",
    answer: "Não. Incluímos o Guia Vitrine — um checklist prático para tirar uma boa foto com celular em 10 minutos.",
  },
];
---

<section class="py-20 md:py-28 bg-white fade-in-section">
  <div class="mx-auto max-w-3xl px-5">
    <h2 class="font-serif text-3xl md:text-4xl font-bold text-brand-900 text-center leading-tight">
      Perguntas frequentes
    </h2>

    <div class="mt-12 space-y-4">
      {faqs.map((faq, index) => (
        <details class="group bg-neutral-50 rounded-xl border border-neutral-100 hover:border-brand-200 transition-colors">
          <summary class="flex items-center justify-between cursor-pointer p-5 md:p-6 text-left font-semibold text-brand-900 leading-snug select-none focus:outline-2 focus:outline-offset-2 focus:outline-brand-500 rounded-xl">
            <span>{faq.question}</span>
            <svg class="w-5 h-5 text-neutral-400 shrink-0 ml-4 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-5 md:px-6 pb-5 md:pb-6 text-neutral-600 leading-relaxed">
            {faq.answer}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
