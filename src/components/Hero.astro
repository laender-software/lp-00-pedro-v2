---
interface Props {
  whatsappLink: string;
}

const { whatsappLink } = Astro.props;
---

<section class="pt-28 pb-20 md:pt-40 md:pb-28 bg-bg-alt">
  <div class="mx-auto max-w-4xl px-6 text-center">
    <span class="inline-block rounded-full bg-[#DBEAFE] px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-brand">
      Especialista em sites para médicos
    </span>

    <h1 class="mt-6 font-serif text-4xl md:text-5xl lg:text-6xl font-semibold text-text leading-tight">
      Seu site profissional no ar em <em class="not-italic text-brand">5 dias</em>
    </h1>

    <p class="mt-6 text-lg md:text-xl text-muted leading-relaxed max-w-2xl mx-auto">
      Sites modernos, rápidos e que convertem pacientes em consultas. Sem reunião, sem burocracia, sem esperar 30 dias.
    </p>

    <div class="mt-10">
      <a
        href={whatsappLink}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-full bg-brand px-8 py-4 text-base font-bold text-white hover:bg-brand-dark transition-colors btn-pulse"
      >
        Quero meu site profissional
      </a>
    </div>

    <!-- Stats grid -->
    <div class="mt-16 grid grid-cols-2 gap-4 md:gap-6 max-w-md mx-auto reveal">
      <div class="bg-white rounded-2xl p-5 border border-border card-lift">
        <p class="font-serif text-3xl md:text-4xl font-bold text-brand">5 <span class="text-lg font-semibold">dias</span></p>
        <p class="text-sm text-muted mt-1">prazo de entrega</p>
      </div>
      <div class="bg-white rounded-2xl p-5 border border-border card-lift">
        <p class="font-serif text-3xl md:text-4xl font-bold text-brand">5 <span class="text-lg font-semibold">anos</span></p>
        <p class="text-sm text-muted mt-1">de suporte</p>
      </div>
    </div>
  </div>
</section>
