---
const items = [
  { icon: "🙌", text: "Briefing de 10 minutos" },
  { icon: "⚡", text: "Pronto em 5 dias" },
  { icon: "🎨", text: "Design personalizado para a sua especialidade" },
  { icon: "📱", text: "Perfeito no celular e no computador" },
  { icon: "🔍", text: "SEO básico configurado" },
  { icon: "📊", text: "Lighthouse 95+ (site rápido = Google prefere)" },
  { icon: "🛡️", text: "HTTPS incluído (segurança automática)" },
  { icon: "🔧", text: "5 anos de suporte — atualizamos quando precisar" },
];
---

<section id="solucao" class="py-20 md:py-28 bg-white reveal">
  <div class="mx-auto max-w-4xl px-6">
    <span class="text-sm font-semibold uppercase tracking-widest text-accent">A solução</span>
    <h2 class="mt-4 font-serif text-3xl md:text-4xl font-bold text-text leading-tight">
      Simples assim.
    </h2>

    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-4 stagger">
      {items.map((item) => (
        <div class="flex items-center gap-4 bg-bg-alt rounded-xl p-5 border border-border reveal">
          <span class="text-2xl shrink-0" aria-hidden="true">{item.icon}</span>
          <span class="font-semibold text-text">{item.text}</span>
        </div>
      ))}
    </div>
  </div>
</section>
