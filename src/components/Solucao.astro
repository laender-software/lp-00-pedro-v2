---
const items = [
  { icon: "⚡", text: "Entrega em até 5 dias úteis" },
  { icon: "📱", text: "Mobile perfeito (testado em iPhone e Android)" },
  { icon: "🔍", text: "SEO básico configurado (Google encontra você)" },
  { icon: "💬", text: "WhatsApp flutuante + botão de agendamento" },
  { icon: "🎨", text: "Design personalizado (não é template genérico)" },
  { icon: "🌐", text: "Domínio próprio configurado por nós" },
  { icon: "🔄", text: "1 rodada de ajustes incluída" },
  { icon: "🚀", text: "Lighthouse 95+ (site rápido = Google prefere)" },
  { icon: "🔒", text: "HTTPS incluído (segurança automática)" },
  { icon: "🛠️", text: "Suporte por 5 anos — atualizo quando precisar" },
];
---

<section class="py-20 md:py-28 bg-white reveal">
  <div class="mx-auto max-w-4xl px-6">
    <span class="text-sm font-semibold uppercase tracking-widest text-accent">Sem letra miúda</span>
    <h2 class="mt-4 font-serif text-3xl md:text-4xl font-bold text-text leading-tight">
      O que está incluído
    </h2>

    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-4 stagger">
      {items.map((item) => (
        <div class="flex items-center gap-4 bg-bg-alt rounded-xl p-5 border border-border reveal">
          <span class="text-2xl shrink-0" aria-hidden="true">{item.icon}</span>
          <span class="font-semibold text-text">{item.text}</span>
        </div>
      ))}
    </div>
  </div>
</section>
