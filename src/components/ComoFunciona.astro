---
const steps = [
  {
    number: "01",
    title: "Briefing rápido",
    text: "Responda algumas perguntas sobre sua especialidade e consultório. Sem reuniões, sem formulários extensos. 10-15 minutos.",
  },
  {
    number: "02",
    title: "Pesquisamos e criamos tudo",
    text: "Texto profissional, design exclusivo para a sua especialidade, domínio próprio. Tudo por conta nossa.",
  },
  {
    number: "03",
    title: "Site no ar em 5 dias",
    text: "Seu site profissional funcionando, bonito no celular e no computador. Pronto para compartilhar.",
  },
  {
    number: "04",
    title: "5 anos sem se preocupar",
    text: "Domínio, manutenção, tudo funcionando. Precisa trocar foto ou telefone? Nós fazemos.",
  },
];
---

<section id="como-funciona" class="py-20 md:py-28 bg-white reveal">
  <div class="mx-auto max-w-4xl px-6">
    <span class="text-sm font-semibold uppercase tracking-widest text-accent">Processo</span>
    <h2 class="mt-4 font-serif text-3xl md:text-4xl font-bold text-text leading-tight">
      Do briefing ao site no ar. 5 dias úteis.
    </h2>

    <div class="mt-14 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 stagger">
      {steps.map((step) => (
        <div class="bg-bg-alt rounded-2xl p-6 border border-border card-lift reveal">
          <span class="font-serif text-4xl font-bold text-brand opacity-20">{step.number}</span>
          <h3 class="mt-2 text-base font-semibold text-text leading-snug">{step.title}</h3>
          <p class="mt-2 text-muted leading-relaxed text-sm">{step.text}</p>
        </div>
      ))}
    </div>

  </div>
</section>
